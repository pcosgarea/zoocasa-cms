# Supabase Database
# Get these from: Supabase Dashboard → Settings → Database → Connection string
# DATABASE_URL: Use "Transaction" mode (port 6543) with ?pgbouncer=true
# DIRECT_URL: Use "Session" mode (port 5432) for migrations
DATABASE_URL=""
DIRECT_URL=""

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Vercel Blob (for images)
BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"

# Optional: Analytics
NEXT_PUBLIC_GA_ID="your-google-analytics-id"
